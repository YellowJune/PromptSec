# PromptSec Environment Configuration
PROJECT_NAME=PromptSec
VERSION=0.1.0

# Database
DATABASE_URL=sqlite:///./promptsec.db

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
OPENAI_API_KEY=
HUGGINGFACE_MODEL_PATH=distilgpt2
HUGGINGFACE_TOKEN=

# Detector Weights
DETECTOR_RULE_WEIGHT=0.3
DETECTOR_HEURISTIC_WEIGHT=0.3
DETECTOR_LLM_WEIGHT=0.4
DETECTOR_RISK_THRESHOLD=0.6

# Celery (optional)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
